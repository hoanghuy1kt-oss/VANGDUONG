rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user is admin
    function isAdmin() {
      return isAuthenticated() && 
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Helper function to check file size (max 10MB)
    function isUnderSizeLimit() {
      return request.resource.size < 10 * 1024 * 1024;
    }
    
    // Helper function to check file type (images and PDFs only)
    function isAllowedFileType() {
      return request.resource.contentType.matches('image/.*') ||
             request.resource.contentType == 'application/pdf';
    }

    // Invoice files - anyone authenticated can upload
    match /invoices/{projectCode}/{fileName} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isUnderSizeLimit() && isAllowedFileType();
      allow delete: if isAdmin();
    }
    
    // User avatars
    match /avatars/{userId}/{fileName} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && 
        (request.auth.uid == userId || isAdmin()) &&
        isUnderSizeLimit() &&
        request.resource.contentType.matches('image/.*');
    }
  }
}
